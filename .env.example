# ── Backend (copy to backend/.env) ────────────────────────────────────────────

# API Keys (required)
ANTHROPIC_API_KEY=your-anthropic-api-key
TAVILY_API_KEY=your-tavily-api-key

# Supabase (required for deployment, optional for local dev)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Admin endpoint — protect POST /api/v1/admin/refresh-agencies
ADMIN_SECRET=choose-a-random-secret

# CORS — comma-separated list of allowed origins
# Local dev: leave as-is. Production: add your Vercel URL.
BACKEND_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3005

# ── Frontend (copy to frontend/.env.local) ─────────────────────────────────────

NEXT_PUBLIC_API_URL=https://your-backend.railway.app
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
